nimport Top from './Top'\nimport Banner from './Banner'\nimport $ from 'jquery'\nimport Bot from './Bottom'\n\nclass FrontPage extends React.Component{\n    constructor(props){\n        super(props)\n    }\n    state = {\n        dataset: []\n    }\n    \n    componentDidMount(){\n        $('#morebtn').on('click',function(){\n            $('#morebtn').css(\"display\",\"none\");\n        })\n        \n        fetch(\"http://127.0.0.1:8085/data\")\n        .then((response)=>response.json())\n        .then((data)=>{\n            this.setState({\n                dataset : data\n            })\n        });\n\n       \n    }\n\n\n    \n\n\n    render(){\n        return(\n            <Fragment>\n                <Top/>\n                <Banner/>\n                <div class = \"info\">\n                    <div class = \"info-head\">\n                        Most Popular Items\n                    </div>\n                    <div class= \"box-father\">\n\n                         \n                        {\n                            this.state.dataset.filter(item => item[\"recommended\"] == \"true\").map((item1)=>(\n                                <Card img = {item1[\"image\"]} name = {item1[\"name\"]} price = {item1[\"price\"]} info = {item1} id = {item1[\"id\"]}  url = {\"/shoes/\" + item1[\"id\"]} ></Card>\n                            ))\n                        }\n      \n                    </div>\n                    \n                    \n                    <div id=\"accordion\">\n                         <p>\n                        \n                            <button id = \"morebtn\" class=\"btn btn-outline-dark\" type=\"button\" data-toggle=\"collapse\" data-target=\"#collapseExample\" aria-expanded=\"false\" aria-controls=\"collapseExample\">\n                                More\n                            </button>\n                        </p>\n                        <div class=\"collapse\" id=\"collapseExample\">\n                            <div class= \"box-father\">\n\n                                <Card img = {'offvape.jpg'} name = {\"OffWhite x Vapormax\"} price = \"1000\"/>\n                                <Card img = {'offvape.jpg'} name = {\"OffWhite x Vapormax\"} price = \"1000\"/>\n                                <Card img = {'offvape.jpg'} name = {\"OffWhite x Vapormax\"} price = \"1000\"/>\n                                <Card img = {'offvape.jpg'} name = {\"OffWhite x Vapormax\"}/>\n\n\n\n                            </div>\n                        </div>\n                    </div>\n                    <Bot/>\n                </div>\n\n               \n                \n\n            \n            </Fragment>\n            \n\n        )\n    }\n}\n\nexport default FrontPage","/Users/Allen/Desktop/sneakers/src/Card.js",["74","75","76","77"],"/Users/Allen/Desktop/sneakers/src/Top.js",["78","79","80","81","82","83","84","85","86","87","88","89","90","91","92","93","94","95","96","97","98","99","100","101"],"/Users/Allen/Desktop/sneakers/src/Banner.js",[],"/Users/Allen/Desktop/sneakers/src/Bottom.js",[],"/Users/Allen/Desktop/sneakers/src/Comps/LoginPage.js",[],"/Users/Allen/Desktop/sneakers/src/Comps/ShortCut.js",["102","103"],"import React , {Component,Fragment} from 'react';\nimport '../css/SC.css'\nclass ShortCut extends Component{\n    render(){\n        return(\n            <Fragment>\n                <div class = \"short-bg\">\n                    <a href = \"#\">Sneakers</a> &#62; \n                    <a href = \"#\"> Login</a>\n\n                </div>\n\n                \n            </Fragment>\n        )\n    }\n}\n\nexport default ShortCut;","/Users/Allen/Desktop/sneakers/src/Comps/Details.js",["104","105","106","107","108","109","110","111","112","113","114","115","116","117"],"/Users/Allen/Desktop/sneakers/src/Comps/Gallery.js",["118"],"/Users/Allen/Desktop/sneakers/src/Comps/RadioBtns.js",["119"],"/Users/Allen/Desktop/sneakers/src/Comps/ShoppingCart.js",["120","121"],"/Users/Allen/Desk